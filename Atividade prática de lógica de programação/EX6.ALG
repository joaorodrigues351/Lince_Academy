Algoritmo "ex6"
Var
   cateto1: real
   cateto2: real
   hipotenusa: real
Inicio
   escreva("Digite o valor do primeiro cateto: ")
   leia(cateto1)
   escreva("Digite o valor do segundo cateto: ")
   leia(cateto2)
  hipotenusa <- raizq((cateto1 * cateto1) + (cateto2 * cateto2))
   escreval("A hipotenusa È:", hipotenusa:)
Fimalgoritmo